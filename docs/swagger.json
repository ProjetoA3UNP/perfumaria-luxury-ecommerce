{
  "openapi": "3.0.0",
  "info": {
    "title": "Essence API - Alta Perfumaria",
    "description": "Documentação Oficial AV3 (Swagger UI)",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Servidor Local de Desenvolvimento"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Cadastra um novo usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": { "type": "string", "example": "João da Silva" },
                  "email": { "type": "string", "example": "joao.essence@gmail.com" },
                  "cpf": { "type": "string", "example": "12345678912" },
                  "senha": { "type": "string", "example": "senhaforte123" },
                  "data_nascimento": { "type": "string", "format": "date", "example": "1994-10-25" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuário cadastrado com sucesso!" },
          "400": { "description": "Validação de dados falhou." }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Realiza login e devolve o Token JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "admin@essence.com" },
                  "senha": { "type": "string", "example": "senha1234" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login bem sucedido com Token JWT retornado." },
          "401": { "description": "Credenciais inválidas." }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Solicita recuperação de senha",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "usuario@email.com" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Instruções enviadas para o e-mail." }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Autenticação (Protegido)"],
        "summary": "Retorna os dados do usuário logado",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Dados do usuário retornados com sucesso." }
        }
      },
      "put": {
        "tags": ["Autenticação (Protegido)"],
        "summary": "Atualiza os dados do usuário logado",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": { "type": "string", "example": "João da Silva Sauro" },
                  "data_nascimento": { "type": "string", "example": "1994-10-25" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Perfil atualizado." }
        }
      }
    },
    "/api/products": {
      "get": {
        "tags": ["Catálogo"],
        "summary": "Lista todos os perfumes com suas notas olfativas",
        "responses": {
          "200": { "description": "Lista de produtos retornada." }
        }
      },
      "post": {
        "tags": ["Catálogo (Admin)"],
        "summary": "Cadastra um novo perfume (Requer Admin)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": { "type": "string", "example": "Versace Eros" },
                  "marca_id": { "type": "integer", "example": 8 },
                  "preco": { "type": "number", "example": 650.00 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Perfume criado." }
        }
      }
    },
    "/api/products/menu-filters": {
      "get": {
        "tags": ["Catálogo"],
        "summary": "Retorna os filtros para o menu (categorias, marcas, famílias)",
        "responses": {
          "200": { "description": "Filtros retornados com sucesso." }
        }
      }
    },
    "/api/products/{id}": {
      "get": {
        "tags": ["Catálogo"],
        "summary": "Busca detalhes e pirâmide olfativa de um perfume específico",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Perfume retornado com sucesso." },
          "404": { "description": "Perfume não encontrado." }
        }
      },
      "put": {
        "tags": ["Catálogo (Admin)"],
        "summary": "Atualiza os dados de um produto",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Produto atualizado com sucesso." }
        }
      }
    },
    "/api/cart": {
      "get": {
        "tags": ["Carrinho (Protegido)"],
        "summary": "Lista o carrinho de compras do usuário",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Carrinho retornado com o total matemático." }
        }
      }
    },
    "/api/cart/add": {
      "post": {
        "tags": ["Carrinho (Protegido)"],
        "summary": "Adiciona um perfume ao carrinho",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "produto_id": { "type": "integer", "example": 1 },
                  "quantidade": { "type": "integer", "example": 1 },
                  "variacao_id": { "type": "integer", "example": 2 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Item adicionado." }
        }
      }
    },
    "/api/cart/update/{variacao_id}": {
      "put": {
        "tags": ["Carrinho (Protegido)"],
        "summary": "Atualiza a quantidade de um item no carrinho",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "variacao_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "quantidade": { "type": "integer", "example": 2 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Quantidade atualizada." }
        }
      }
    },
    "/api/cart/remove/{variacao_id}": {
      "delete": {
        "tags": ["Carrinho (Protegido)"],
        "summary": "Remove um item do carrinho",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "variacao_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Removido com sucesso." }
        }
      }
    },
    "/api/coupons/validate": {
      "post": {
        "tags": ["Cupons (Protegido)"],
        "summary": "Valida um código de cupom",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "codigo": { "type": "string", "example": "PRIMEIRA10" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Cupom válido." },
          "400": { "description": "Cupom inválido ou expirado." }
        }
      }
    },
    "/api/addresses": {
      "get": {
        "tags": ["Endereços (Protegido)"],
        "summary": "Lista os endereços do usuário",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Endereços retornados." }
        }
      },
      "post": {
        "tags": ["Endereços (Protegido)"],
        "summary": "Adiciona um novo endereço",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Endereço criado." }
        }
      }
    },
    "/api/addresses/{id}": {
      "put": {
        "tags": ["Endereços (Protegido)"],
        "summary": "Atualiza um endereço",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Endereço atualizado." }
        }
      },
      "delete": {
        "tags": ["Endereços (Protegido)"],
        "summary": "Deleta um endereço",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Endereço deletado." }
        }
      }
    },
    "/api/favorites": {
      "get": {
        "tags": ["Favoritos (Protegido)"],
        "summary": "Lista a wishlist (favoritos) do usuário",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Lista de produtos retornada." }
        }
      },
      "post": {
        "tags": ["Favoritos (Protegido)"],
        "summary": "Adiciona um perfume aos favoritos",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Adicionado aos favoritos com sucesso." }
        }
      }
    },
    "/api/favorites/{produto_id}": {
      "delete": {
        "tags": ["Favoritos (Protegido)"],
        "summary": "Remove um perfume dos favoritos",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "produto_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Removido dos favoritos." }
        }
      }
    },
    "/api/orders": {
      "get": {
        "tags": ["Pedidos e Checkout (Protegido)"],
        "summary": "Lista o histórico de compras do usuário",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Histórico retornado." }
        }
      }
    },
    "/api/orders/create-payment-intent": {
      "post": {
        "tags": ["Pedidos e Checkout (Protegido)"],
        "summary": "Gera intenção de pagamento na Stripe",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Token gerado (clientSecret)." }
        }
      }
    },
    "/api/orders/checkout": {
      "post": {
        "tags": ["Pedidos e Checkout (Protegido)"],
        "summary": "Finaliza o pedido",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Pedido salvo com sucesso!" }
        }
      }
    },
    "/api/orders/admin/all": {
      "get": {
        "tags": ["Pedidos (Admin)"],
        "summary": "Lista todos os pedidos (Requer Admin)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Pedidos retornados." }
        }
      }
    },
    "/api/orders/admin/{id}/status": {
      "patch": {
        "tags": ["Pedidos (Admin)"],
        "summary": "Atualiza o status de um pedido e registra log",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "novo_status": { "type": "string", "example": "ENVIADO" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Status atualizado." }
        }
      }
    },
    "/api/orders/admin/logs": {
      "get": {
        "tags": ["Pedidos (Admin)"],
        "summary": "Retorna o log de alterações de status",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Logs retornados." }
        }
      }
    },
    "/api/reviews/{produto_id}": {
      "get": {
        "tags": ["Avaliações"],
        "summary": "Retorna as avaliações de um produto",
        "parameters": [
          { "name": "produto_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Avaliações retornadas." }
        }
      }
    },
    "/api/reviews": {
      "post": {
        "tags": ["Avaliações (Protegido)"],
        "summary": "Cria uma nova avaliação para um produto",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Avaliação criada com sucesso." },
          "403": { "description": "Usuário não comprou o produto." }
        }
      }
    },
    "/api/reviews/can-review/{produto_id}": {
      "get": {
        "tags": ["Avaliações (Protegido)"],
        "summary": "Verifica se o usuário pode avaliar o produto",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "produto_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Status de permissão retornado." }
        }
      }
    },
    "/api/dashboard": {
      "get": {
        "tags": ["Dashboard (Admin)"],
        "summary": "Retorna métricas administrativas (faturamento, totais)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Métricas retornadas com sucesso." }
        }
      }
    }
  }
}
