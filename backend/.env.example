# ==========================================
# Configurações do Banco de Dados MySQL
# ==========================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_do_mysql_aqui
DB_NAME=essence_db
DB_PORT=3306

# ==========================================
# Autenticação e Segurança (JWT)
# ==========================================
# Chave secreta para assinar os tokens dos usuários
JWT_SECRET=coloque_uma_chave_secreta_segura_aqui

# ==========================================
# Integrações de Pagamento (Stripe)
# ==========================================
# Pegue esta chave de teste no painel de desenvolvedor da Stripe (começa com sk_test_)
STRIPE_SECRET_KEY=sk_test_sua_chave_secreta_aqui
